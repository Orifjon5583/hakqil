[Unit]
Description=Robbit Monitor API
After=network.target postgresql.service

[Service]
Type=simple
WorkingDirectory=/var/www/robbit-monitor/backend
Environment=NODE_ENV=production
ExecStart=/usr/bin/node dist/server.js
Restart=always
RestartSec=5
User=www-data
Group=www-data

[Install]
WantedBy=multi-user.target
